    return this.jobsService.findAllCategories();
  }

  @Post('categories')
  @ApiOperation({ summary: 'Crear una nueva categoría de empleo' })
  createCategory(@Body() createCategoryDto: any) { 
    return this.jobsService.createCategory(createCategoryDto);
  }
}
